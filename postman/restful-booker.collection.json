{
  "info": {
    "name": "Restful-Booker API",
    "description": "QA portfolio collection covering auth, CRUD bookings, and error handling for the Restful-Booker demo API.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Generate Token — Valid Credentials",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{adminUser}}\",\n  \"password\": \"{{adminPass}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth",
              "host": ["{{baseUrl}}"],
              "path": ["auth"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains token', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('token');",
                  "  pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "// Save token for use in authenticated requests",
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.environment.set('authToken', json.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Generate Token — Invalid Credentials",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"wronguser\",\n  \"password\": \"wrongpass\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth",
              "host": ["{{baseUrl}}"],
              "path": ["auth"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  // API returns 200 even on bad creds, but with a reason field",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains bad credentials reason', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('reason');",
                  "  pm.expect(json.reason).to.equal('Bad credentials');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Get All Bookings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": ["{{baseUrl}}"],
              "path": ["booking"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each item has a bookingid', function () {",
                  "  const json = pm.response.json();",
                  "  json.forEach(function (item) {",
                  "    pm.expect(item).to.have.property('bookingid');",
                  "    pm.expect(item.bookingid).to.be.a('number');",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Bookings — Filter by Name",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/booking?firstname=Jim&lastname=Brown",
              "host": ["{{baseUrl}}"],
              "path": ["booking"],
              "query": [
                { "key": "firstname", "value": "Jim" },
                { "key": "lastname", "value": "Brown" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Bookings — Filter by Check-in Date",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/booking?checkin=2024-01-01&checkout=2024-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["booking"],
              "query": [
                { "key": "checkin", "value": "2024-01-01" },
                { "key": "checkout", "value": "2024-12-31" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Booking — Valid",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Jane\",\n  \"lastname\": \"Tester\",\n  \"totalprice\": 150,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2025-06-01\",\n    \"checkout\": \"2025-06-07\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": ["{{baseUrl}}"],
              "path": ["booking"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains bookingid', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('bookingid');",
                  "  pm.expect(json.bookingid).to.be.a('number');",
                  "});",
                  "",
                  "pm.test('Response contains booking object', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('booking');",
                  "  pm.expect(json.booking.firstname).to.equal('Jane');",
                  "  pm.expect(json.booking.lastname).to.equal('Tester');",
                  "  pm.expect(json.booking.totalprice).to.equal(150);",
                  "  pm.expect(json.booking.depositpaid).to.be.true;",
                  "});",
                  "",
                  "pm.test('Booking dates are correct', function () {",
                  "  const dates = pm.response.json().booking.bookingdates;",
                  "  pm.expect(dates.checkin).to.equal('2025-06-01');",
                  "  pm.expect(dates.checkout).to.equal('2025-06-07');",
                  "});",
                  "",
                  "// Save bookingId for downstream requests",
                  "const json = pm.response.json();",
                  "if (json.bookingid) {",
                  "  pm.environment.set('bookingId', json.bookingid);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Booking — Missing Required Fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Jane\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/booking",
              "host": ["{{baseUrl}}"],
              "path": ["booking"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 500 for incomplete payload', function () {",
                  "  // Restful-Booker returns 500 when required fields are missing",
                  "  pm.response.to.have.status(500);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Booking by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/booking/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has required booking fields', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('firstname');",
                  "  pm.expect(json).to.have.property('lastname');",
                  "  pm.expect(json).to.have.property('totalprice');",
                  "  pm.expect(json).to.have.property('depositpaid');",
                  "  pm.expect(json).to.have.property('bookingdates');",
                  "});",
                  "",
                  "pm.test('Booking dates object has checkin and checkout', function () {",
                  "  const dates = pm.response.json().bookingdates;",
                  "  pm.expect(dates).to.have.property('checkin');",
                  "  pm.expect(dates).to.have.property('checkout');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Authenticated Operations",
      "item": [
        {
          "name": "Update Booking — Full (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Cookie", "value": "token={{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Jane\",\n  \"lastname\": \"Updated\",\n  \"totalprice\": 200,\n  \"depositpaid\": false,\n  \"bookingdates\": {\n    \"checkin\": \"2025-07-01\",\n    \"checkout\": \"2025-07-05\"\n  },\n  \"additionalneeds\": \"Late checkout\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/booking/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Updated fields are reflected in response', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.lastname).to.equal('Updated');",
                  "  pm.expect(json.totalprice).to.equal(200);",
                  "  pm.expect(json.depositpaid).to.be.false;",
                  "});",
                  "",
                  "pm.test('Updated booking dates are correct', function () {",
                  "  const dates = pm.response.json().bookingdates;",
                  "  pm.expect(dates.checkin).to.equal('2025-07-01');",
                  "  pm.expect(dates.checkout).to.equal('2025-07-05');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Booking — Partial (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Cookie", "value": "token={{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Patched\",\n  \"totalprice\": 999\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/booking/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Patched fields are updated', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.firstname).to.equal('Patched');",
                  "  pm.expect(json.totalprice).to.equal(999);",
                  "});",
                  "",
                  "pm.test('Non-patched fields are preserved', function () {",
                  "  const json = pm.response.json();",
                  "  // lastname should still be what PUT set it to",
                  "  pm.expect(json).to.have.property('lastname');",
                  "  pm.expect(json).to.have.property('bookingdates');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Booking",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Cookie", "value": "token={{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/booking/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 on successful delete', function () {",
                  "  // Restful-Booker returns 201 (not 204) on delete",
                  "  pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Deleted Booking — Expect 404",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/booking/{{bookingId}}",
              "host": ["{{baseUrl}}"],
              "path": ["booking", "{{bookingId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 404 after deletion', function () {",
                  "  pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
